generator client {
  provider = "prisma-client-js"
}

generator dbml {
  provider = "prisma-dbml-generator"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Tenant Root ───────────────────────────────────────────────────────────────

model Restaurant {
  id           String   @id @default(uuid())
  name         String
  slug         String   @unique
  ownerId      String
  planType     String   @default("FREE")
  logoUrl      String?
  description  String?
  address      String?
  phone        String?
  email        String?
  primaryColor String?  @default("#FF380B")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  metadata     Json?
  latitude     Float?
  longitude    Float?
  cuisineType  String?  @default("other") // e.g. "vietnamese", "japanese", "fastfood", "other"

  owner                User                 @relation("RestaurantOwner", fields: [ownerId], references: [id])
  userRoles            UserRole[]
  employees            Employee[]
  floors               Floor[]
  tables               Table[]
  categories           Category[]
  dishes               Dish[]
  ingredients          Ingredient[]
  ingredientCategories IngredientCategory[]
  suppliers            Supplier[]
  orders               Order[]
  reservations         Reservation[]
  promotions           Promotion[]
  mealCombos           MealCombo[]
  notifications        Notification[]
  aiChatSessions       AIChatSession[]
  documents            RestaurantDocument[]
  buckets              RestaurantBucket[]
  wallet               RestaurantWallet?

  @@map("Restaurants")
}


// ─── Identity & Auth ───────────────────────────────────────────────────────────

model Role {
  id   String @id @default(uuid())
  name String @unique

  userRoles UserRole[]

  @@map("Roles")
}

model User {
  id            String    @id @default(uuid())
  userName      String?   @unique
  email         String?   @unique
  emailVerified Boolean   @default(false)
  passwordHash  String?
  /// "local" | "google" — how the account was created / primary auth
  provider      String    @default("local")
  phoneNumber   String?
  avatarUrl     String?
  fullName      String?
  /// "MALE" | "FEMALE" | "OTHER"
  gender        String?
  dateOfBirth   DateTime?
  address       String?   @db.VarChar(255)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  resetOtp      String?
  resetOtpExpires DateTime?

  twoFactorEnabled     Boolean   @default(false)
  twoFactorSecret      String?
  twoFactorBackupCodes String[]  @default([])

  employee         Employee?
  customer         Customer?
  roles            UserRole[]
  sessions         UserSession[]
  ownedRestaurants Restaurant[] @relation("RestaurantOwner")
  restaurantApplications RestaurantApplication[]
  reviewedApplications   RestaurantApplication[] @relation("ApplicationReviewer")

  @@map("Users")
}

model UserSession {
  id           String    @id @default(uuid())
  userId       String
  refreshToken String    @unique
  deviceInfo   String? // "Chrome on Windows", "iPhone App"
  ipAddress    String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  revokedAt    DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("UserSessions")
}

model UserRole {
  userId       String
  roleId       String
  restaurantId String?

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role        @relation(fields: [roleId], references: [id], onDelete: Cascade)
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([restaurantId])
  @@map("UserRoles")
}

// ─── People ────────────────────────────────────────────────────────────────────

model Employee {
  id              String    @id @default(uuid())
  code            String
  restaurantId    String
  userId          String?   @unique
  address         String?
  position        String
  hireDate        DateTime  @db.Date
  terminationDate DateTime? @db.Date
  salary          Decimal   @db.Decimal(18, 2)
  salaryType      String
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  modifiedBy      String?
  metadata        Json?

  user              User?              @relation(fields: [userId], references: [id])
  restaurant        Restaurant         @relation(fields: [restaurantId], references: [id])
  ordersHandled     Order[]
  paymentsProcessed Payment[]
  schedules         EmployeeSchedule[]

  @@unique([code, restaurantId])
  @@index([restaurantId])
  @@map("Employees")
}

model Customer {
  id              String    @id @default(uuid())
  userId          String    @unique
  membershipLevel String?
  loyaltyPoints   Int       @default(0)
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  modifiedBy      String?
  metadata        Json?

  user               User                @relation(fields: [userId], references: [id])
  orders             Order[]
  reservations       Reservation[]
  pointsTransactions PointsTransaction[]
  feedbacks          Feedback[]

  @@map("Customers")
}

// ─── Floor & Table ─────────────────────────────────────────────────────────────

model Floor {
  id           String   @id @default(uuid())
  name         String
  restaurantId String
  imageUrl     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  height       Decimal  @default(0.0) @db.Decimal(8, 2)
  width        Decimal  @default(0.0) @db.Decimal(8, 2)
  metadata     Json?

  restaurant Restaurant @relation(fields: [restaurantId], references: [id])
  tables     Table[]

  @@index([restaurantId])
  @@map("Floors")
}

model Table {
  id                 String   @id @default(uuid())
  code               String
  restaurantId       String
  type               String
  seatingCapacity    Int
  shape              String
  positionX          Decimal  @db.Decimal(8, 2)
  positionY          Decimal  @db.Decimal(8, 2)
  width              Decimal  @db.Decimal(6, 2)
  height             Decimal  @db.Decimal(6, 2)
  rotation           Decimal  @db.Decimal(5, 2)
  has3DView          Boolean  @default(false)
  viewDescription    String?
  defaultViewUrl     String?
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String?
  modifiedBy         String?
  tableStatusId      String
  qrCodeUrl          String?
  floorId            String   @default("00000000-0000-0000-0000-000000000000")
  metadata           Json?
  cubeBackImageUrl   String?
  cubeBottomImageUrl String?
  cubeFrontImageUrl  String?
  cubeLeftImageUrl   String?
  cubeRightImageUrl  String?
  cubeTopImageUrl    String?

  restaurant    Restaurant         @relation(fields: [restaurantId], references: [id])
  floor         Floor              @relation(fields: [floorId], references: [id])
  tableStatus   StatusValue        @relation("TableStatus", fields: [tableStatusId], references: [id])
  table3DModels Table3DModel[]
  sessions      TableSession[]
  reservations  ReservationTable[]

  @@unique([code, restaurantId])
  @@index([restaurantId])
  @@map("Tables")
}

model Table3DModel {
  id                String   @id @default(uuid())
  tableId           String   @unique
  modelUrl          String
  modelFormat       String?
  environmentMapUrl String?
  backgroundColor   String?
  cameraX           Decimal  @db.Decimal(8, 4)
  cameraY           Decimal  @db.Decimal(8, 4)
  cameraZ           Decimal  @db.Decimal(8, 4)
  cameraFOV         Decimal  @db.Decimal(5, 2)
  allowRotation     Boolean
  allowZoom         Boolean
  minZoom           Decimal  @db.Decimal(4, 2)
  maxZoom           Decimal  @db.Decimal(4, 2)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String?
  modifiedBy        String?
  metadata          Json?

  table Table @relation(fields: [tableId], references: [id], onDelete: Cascade)

  @@map("Table3DModels")
}

// ─── Menu ──────────────────────────────────────────────────────────────────────

model Category {
  id           String   @id @default(uuid())
  name         String
  description  String
  restaurantId String
  imageUrl     String?
  parentId     String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  metadata     Json?
  displayOrder Int      @default(0)

  restaurant Restaurant                @relation(fields: [restaurantId], references: [id])
  parent     Category?                 @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children   Category[]                @relation("CategoryHierarchy")
  dishes     Dish[]
  promotions PromotionApplicableItem[]

  @@index([restaurantId])
  @@map("Categories")
}

model Dish {
  id                 String   @id @default(uuid())
  categoryId         String
  restaurantId       String
  name               String
  description        String
  price              Decimal  @db.Decimal(18, 2)
  unit               String
  imageUrl           String?
  isVegetarian       Boolean  @default(false)
  isSpicy            Boolean  @default(false)
  isBestSeller       Boolean  @default(false)
  isActive           Boolean  @default(true)
  autoDisableByStock Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String?
  modifiedBy         String?
  metadata           Json?

  restaurant   Restaurant                @relation(fields: [restaurantId], references: [id])
  category     Category                  @relation(fields: [categoryId], references: [id])
  orderDetails OrderDetail[]
  images       DishImage[]
  recipes      DishRecipe[]
  promotions   PromotionApplicableItem[]
  comboDetails ComboDetail[]

  @@index([restaurantId])
  @@index([categoryId])
  @@index([isActive])
  @@index([isBestSeller])
  @@map("Dishes")
}

model DishImage {
  id           String   @id @default(uuid())
  dishId       String
  imageUrl     String
  displayOrder Int
  isActive     Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  imageType    Int      @default(0)
  metadata     Json?

  dish Dish @relation(fields: [dishId], references: [id], onDelete: Cascade)

  @@map("DishImages")
}

// ─── Ingredients & Stock ───────────────────────────────────────────────────────

model IngredientCategory {
  id           String   @id @default(uuid())
  name         String
  code         String
  restaurantId String
  description  String?
  isActive     Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  metadata     Json?

  restaurant  Restaurant   @relation(fields: [restaurantId], references: [id])
  ingredients Ingredient[]

  @@unique([code, restaurantId])
  @@index([restaurantId])
  @@map("IngredientCategories")
}

model Supplier {
  id           String   @id @default(uuid())
  name         String
  restaurantId String
  phone        String?
  email        String?
  address      String?
  isActive     Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  metadata     Json?

  restaurant  Restaurant   @relation(fields: [restaurantId], references: [id])
  ingredients Ingredient[]

  @@index([restaurantId])
  @@map("Suppliers")
}

model Ingredient {
  id                   String   @id @default(uuid())
  name                 String
  code                 String
  restaurantId         String
  unit                 String
  minStockLevel        Decimal  @db.Decimal(10, 3)
  maxStockLevel        Decimal  @db.Decimal(10, 3)
  supplierId           String?
  type                 String?
  isActive             Boolean
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  createdBy            String?
  modifiedBy           String?
  ingredientCategoryId String?
  status               Int      @default(0)
  metadata             Json?

  restaurant        Restaurant          @relation(fields: [restaurantId], references: [id])
  category          IngredientCategory? @relation(fields: [ingredientCategoryId], references: [id])
  supplier          Supplier?           @relation(fields: [supplierId], references: [id])
  inventoryStock    InventoryStock?
  stockTransactions StockTransaction[]
  dishRecipes       DishRecipe[]

  @@unique([code, restaurantId])
  @@index([restaurantId])
  @@map("Ingredients")
}

model InventoryStock {
  id              String    @id @default(uuid())
  ingredientId    String    @unique
  currentQuantity Decimal   @db.Decimal(10, 3)
  lastRestockDate DateTime?
  lastUpdated     DateTime
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  modifiedBy      String?
  metadata        Json?

  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@map("InventoryStocks")
}

model StockTransaction {
  id              String   @id @default(uuid())
  ingredientId    String
  transactionType String?
  quantity        Decimal  @db.Decimal(10, 3)
  unitPrice       Decimal  @db.Decimal(18, 2)
  totalAmount     Decimal  @db.Decimal(18, 2)
  reference       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  modifiedBy      String?
  metadata        Json?

  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@index([ingredientId])
  @@index([createdAt])
  @@map("StockTransactions")
}

model DishRecipe {
  id           String   @id @default(uuid())
  dishId       String
  ingredientId String
  quantity     Decimal  @db.Decimal(10, 3)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  metadata     Json?

  dish       Dish       @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id])

  @@map("DishRecipes")
}

// ─── Combos ────────────────────────────────────────────────────────────────────

model MealCombo {
  id           String   @id @default(uuid())
  name         String
  code         String
  restaurantId String
  description  String
  imageUrl     String?
  baseCost     Decimal  @db.Decimal(18, 2)
  price        Decimal  @db.Decimal(18, 2)
  isActive     Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  metadata     Json?

  restaurant   Restaurant                @relation(fields: [restaurantId], references: [id])
  comboDetails ComboDetail[]
  promotions   PromotionApplicableItem[]
  orderDetails OrderDetail[]

  @@unique([code, restaurantId])
  @@index([restaurantId])
  @@map("MealCombos")
}

model ComboDetail {
  id         String   @id @default(uuid())
  comboId    String
  dishId     String
  quantity   Int
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  modifiedBy String?
  metadata   Json?

  combo MealCombo @relation(fields: [comboId], references: [id], onDelete: Cascade)
  dish  Dish      @relation(fields: [dishId], references: [id])

  @@map("ComboDetails")
}

// ─── Loyalty ───────────────────────────────────────────────────────────────────

model LoyaltyPointBand {
  id                 String   @id @default(uuid())
  name               String
  min                Int
  max                Int?
  discountPercentage Decimal  @db.Decimal(5, 2)
  benefitDescription String
  isActive           Boolean
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  createdBy          String?
  modifiedBy         String?
  logoColor          String?
  metadata           Json?

  @@map("LoyaltyPointBands")
}

// ─── Notifications ─────────────────────────────────────────────────────────────

model Notification {
  id               String    @id @default(uuid())
  restaurantId     String?
  recipientId      String?
  notificationType String?
  isBroadcast      Boolean
  title            String
  message          String
  imageUrl         String?
  priority         String?
  isPublished      Boolean
  expiryDate       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        String?
  modifiedBy       String?
  metadata         Json?

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
  @@index([recipientId])
  @@index([isPublished])
  @@index([createdAt])
  @@map("Notifications")
}

// ─── Promotions ────────────────────────────────────────────────────────────────

model Promotion {
  id                String   @id @default(uuid())
  code              String
  restaurantId      String
  name              String
  discountValue     Decimal  @db.Decimal(18, 2)
  discountType      String   @default("PERCENTAGE")
  maxDiscountAmount Decimal  @db.Decimal(18, 2)
  minOrderAmount    Decimal  @db.Decimal(18, 2)
  usageLimit        Int
  usagePerCustomer  Int
  validFrom         DateTime
  validTo           DateTime
  isActive          Boolean
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  createdBy         String?
  modifiedBy        String?
  metadata          Json?

  restaurant      Restaurant                 @relation(fields: [restaurantId], references: [id])
  applicableItems PromotionApplicableItem[]
  histories       PromotionHistory[]

  @@unique([code, restaurantId])
  @@index([restaurantId])
  @@map("Promotions")
}

model PromotionApplicableItem {
  id         String   @id @default(uuid())
  promotionId String
  dishId      String?
  categoryId  String?
  comboId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  modifiedBy  String?
  metadata    Json?

  promotion Promotion  @relation(fields: [promotionId], references: [id], onDelete: Cascade)
  dish      Dish?      @relation(fields: [dishId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  category  Category?  @relation(fields: [categoryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  combo     MealCombo? @relation(fields: [comboId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("PromotionApplicableItems")
}

// ─── Status ────────────────────────────────────────────────────────────────────

model StatusType {
  id         String   @id @default(uuid())
  code       String   @unique
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  modifiedBy String?
  metadata   Json?

  statusValues StatusValue[]

  @@map("StatusTypes")
}

model StatusValue {
  id           String   @id @default(uuid())
  statusTypeId String
  code         String
  name         String
  colorCode    String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  metadata     Json?
  displayOrder Int      @default(1)
  isSystem     Boolean  @default(true)

  statusType        StatusType         @relation(fields: [statusTypeId], references: [id])
  tables            Table[]            @relation("TableStatus")
  employeeSchedules EmployeeSchedule[] @relation("ScheduleStatus")
  reservations      Reservation[]      @relation("ReservationStatus")
  orderDetails      OrderDetail[]      @relation("OrderDetailStatus")

  @@map("StatusValues")
}

// ─── Scheduling ────────────────────────────────────────────────────────────────

model EmployeeSchedule {
  id           String    @id @default(uuid())
  employeeId   String
  workDate     DateTime  @db.Date
  startTime    DateTime  @db.Time
  endTime      DateTime  @db.Time
  checkInTime  DateTime?
  checkOutTime DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  modifiedBy   String?
  statusId     String
  metadata     Json?

  employee    Employee    @relation(fields: [employeeId], references: [id])
  statusValue StatusValue @relation("ScheduleStatus", fields: [statusId], references: [id])

  @@index([employeeId])
  @@index([workDate])
  @@index([statusId])
  @@map("EmployeeSchedules")
}

// ─── Reservations ──────────────────────────────────────────────────────────────

model ReservationTable {
  id            String   @id @default(uuid())
  reservationId String
  tableId       String
  assignedAt    DateTime @default(now())
  assignedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  reservation Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  table       Table       @relation(fields: [tableId], references: [id])

  @@unique([reservationId, tableId])
  @@map("ReservationTables")
}

model Reservation {
  id                  String    @id @default(uuid())
  customerId          String
  restaurantId        String
  numberOfGuests      Int
  time                DateTime
  specialRequests     String?
  depositAmount       Decimal   @db.Decimal(18, 2)
  checkedInAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  createdBy           String?
  modifiedBy          String?
  reservationStatusId String
  confirmationCode    String?   @unique
  metadata            Json?
  paymentDeadline     DateTime?

  restaurant  Restaurant         @relation(fields: [restaurantId], references: [id])
  customer    Customer           @relation(fields: [customerId], references: [id])
  statusValue StatusValue        @relation("ReservationStatus", fields: [reservationStatusId], references: [id])
  orders      Order[]
  payments    Payment[]
  tables      ReservationTable[]

  @@index([restaurantId])
  @@index([customerId])
  @@index([reservationStatusId])
  @@index([time])
  @@map("Reservations")
}

// ─── Orders & Payments ─────────────────────────────────────────────────────────

model Order {
  id             String    @id @default(uuid())
  reference      String    @unique
  restaurantId   String
  customerId     String?
  reservationId  String?
  subTotal       Decimal   @db.Decimal(18, 2)
  discountAmount Decimal   @db.Decimal(18, 2)
  taxAmount      Decimal   @db.Decimal(18, 2)
  serviceCharge  Decimal   @db.Decimal(18, 2)
  totalAmount    Decimal   @db.Decimal(18, 2)
  completedAt    DateTime?
  cancelledAt    DateTime?
  handledBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?
  modifiedBy     String?
  orderStatusId  String
  metadata       Json?

  restaurant         Restaurant          @relation(fields: [restaurantId], references: [id])
  customer           Customer?           @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reservation        Reservation?        @relation(fields: [reservationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employee           Employee?           @relation(fields: [handledBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  orderDetails       OrderDetail[]
  payments           Payment[]
  pointsTransactions PointsTransaction[]
  promotionHistories PromotionHistory[]
  tableSessions      TableSession[]
  feedbacks          Feedback[]

  @@index([restaurantId])
  @@index([customerId])
  @@index([reservationId])
  @@index([orderStatusId])
  @@index([createdAt])
  @@index([handledBy])
  @@map("Orders")
}

model OrderDetail {
  id           String   @id @default(uuid())
  orderId      String
  dishId       String?
  quantity     Int
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  itemStatusId String
  metadata     Json?
  unitPrice    Decimal  @default(0.0) @db.Decimal(18, 2)
  comboPrice   Decimal? @db.Decimal(18, 2)
  comboName    String?
  comboId      String?
  parentId     String?

  order       Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish        Dish?         @relation(fields: [dishId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  combo       MealCombo?    @relation(fields: [comboId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  statusValue StatusValue   @relation("OrderDetailStatus", fields: [itemStatusId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  parent      OrderDetail?  @relation("OrderDetailHierarchy", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  children    OrderDetail[] @relation("OrderDetailHierarchy")

  @@index([orderId])
  @@index([dishId])
  @@index([comboId])
  @@index([itemStatusId])
  @@map("OrderDetails")
}

model PaymentMethod {
  id        String   @id @default(uuid())
  code      String   @unique
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  payments Payment[]

  @@map("PaymentMethods")
}

model Payment {
  id              String    @id @default(uuid())
  orderId         String?
  reservationId   String?
  paymentMethodId String
  transactionId   String?
  amount          Decimal   @db.Decimal(18, 2)
  cashReceive     Decimal   @db.Decimal(18, 2)
  paymentDate     DateTime  @default(now())
  cashback        Decimal   @db.Decimal(18, 2)
  refundDate      DateTime?
  processedBy     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?
  modifiedBy      String?
  checkoutUrl     String?
  payOSOrderCode  BigInt?   @unique
  metadata        Json?
  status          Int       @default(0)
  purpose         Int       @default(0)

  order         Order?        @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reservation   Reservation?  @relation(fields: [reservationId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  employee      Employee?     @relation(fields: [processedBy], references: [id], onDelete: NoAction, onUpdate: NoAction)
  paymentMethod PaymentMethod @relation(fields: [paymentMethodId], references: [id])

  @@index([orderId])
  @@index([reservationId])
  @@index([status])
  @@index([paymentDate])
  @@map("Payments")
}

// ─── Points & Promotions History ───────────────────────────────────────────────

model PointsTransaction {
  id          String   @id @default(uuid())
  customerId  String
  type        String // "EARN" | "REDEEM" | "BONUS" | "ADJUSTMENT" | "EXPIRE"
  points      Int
  orderId     String?
  sourceType  String? // "ORDER" | "REGISTRATION" | "MANUAL" | "SYSTEM"
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  createdBy   String?
  modifiedBy  String?
  metadata    Json?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order    Order?   @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("PointsTransactions")
}

model PromotionHistory {
  id             String   @id @default(uuid())
  promotionId    String
  orderId        String
  discountAmount Decimal  @db.Decimal(18, 2)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  createdBy      String?
  modifiedBy     String?
  metadata       Json?

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promotion Promotion @relation(fields: [promotionId], references: [id])

  @@map("PromotionHistories")
}

// ─── Table Sessions ────────────────────────────────────────────────────────────

model TableSession {
  id         String    @id @default(uuid())
  tableId    String
  orderId    String?
  startedAt  DateTime
  endedAt    DateTime?
  isActive   Boolean
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?
  modifiedBy String?
  metadata   Json?

  table Table  @relation(fields: [tableId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  order Order? @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tableId])
  @@index([isActive])
  @@index([startedAt])
  @@map("TableSessions")
}

// ─── Feedback ──────────────────────────────────────────────────────────────────

model Feedback {
  id         String   @id @default(uuid())
  orderId    String
  customerId String
  rating     Int
  comment    String?
  isPublished Boolean
  isAnonymous Boolean
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  createdBy  String?
  modifiedBy String?
  metadata   Json?

  order    Order           @relation(fields: [orderId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  customer Customer        @relation(fields: [customerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  images   FeedbackImage[]

  @@unique([orderId, customerId])
  @@map("Feedbacks")
}

model FeedbackImage {
  id           String   @id @default(uuid())
  feedbackId   String
  imageUrl     String
  displayOrder Int
  isCover      Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  createdBy    String?
  modifiedBy   String?
  metadata     Json?

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@map("FeedbackImages")
}

// ─── AI Chat ───────────────────────────────────────────────────────────────────

model AIChatSession {
  id           String    @id @default(uuid())
  sessionId    String    @unique
  restaurantId String?
  customerId   String?
  tableId      String?
  expiresAt    DateTime
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  modifiedBy   String?
  metadata     Json?

  restaurant Restaurant?   @relation(fields: [restaurantId], references: [id])
  messages   AIChatMessage[]

  @@index([restaurantId])
  @@map("AIChatSessions")
}

model AIChatMessage {
  id              String   @id @default(uuid())
  aiChatSessionId String
  role            String
  content         String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  modifiedBy      String?
  metadata        Json?

  session AIChatSession @relation(fields: [aiChatSessionId], references: [id], onDelete: Cascade)

  @@map("AIChatMessages")
}

// ─── Restaurant Registration Applications ──────────────────────────────────────

model RestaurantApplication {
  id              String    @id @default(uuid())
  userId          String

  // Step 1 — Restaurant info
  restaurantName  String
  slug            String
  description     String?
  address         String
  phone           String
  email           String
  logoUrl         String?
  latitude        Float?
  longitude       Float?
  cuisineType     String?  @default("other") // "vietnamese"|"japanese"|"fastfood"|"other"

  // Step 2 — Legal documents (AES-256 encrypted Cloudinary URLs)
  // Format: "base64(iv):base64(ciphertext)"
  businessLicenseEnc  String?   // Giấy phép kinh doanh
  ownershipProofEnc   String?   // Giấy sở hữu / hợp đồng thuê mặt bằng
  nationalIdEnc       String?   // CCCD mặt trước
  nationalIdBackEnc   String?   // CCCD mặt sau

  // Review
  status          String    @default("PENDING")  // PENDING | APPROVED | REJECTED
  reviewedBy      String?
  reviewNote      String?
  reviewedAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("ApplicationReviewer", fields: [reviewedBy], references: [id])

  @@index([userId])
  @@index([status])
  @@map("RestaurantApplications")
}

model RestaurantDocument {
  id           String   @id @default(uuid())
  restaurantId String
  bucketId     String?
  filename     String
  fileUrl      String
  fileType     String   // "PDF" | "DOCX" | "TXT" | "URL"
  status       String   @default("PENDING") // "PENDING" | "PROCESSING" | "INDEXED" | "FAILED"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  restaurant   Restaurant        @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  bucket       RestaurantBucket? @relation(fields: [bucketId], references: [id], onDelete: Cascade)
  chunks       DocumentChunk[]

  @@index([restaurantId])
  @@index([bucketId])
  @@map("RestaurantDocuments")
}

model DocumentChunk {
  id         String   @id @default(uuid())
  documentId String
  content    String   @db.Text
  embedding  Unsupported("public.vector(768)")
  metadata   Json?
  createdAt  DateTime @default(now())

  document   RestaurantDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("DocumentChunks")
}

model RestaurantBucket {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  url          String
  description  String?
  isChatEnabled Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Knowledge Base config
  isMounted        Boolean  @default(false)
  chunkingStrategy String   @default("FIXED") // "FIXED" | "SEMANTIC" | "NONE"
  chunkSize        Int      @default(800)
  chunkOverlap     Int      @default(100)

  restaurant   Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  documents    RestaurantDocument[]

  @@unique([restaurantId, name])
  @@map("RestaurantBuckets")
}

// ─── Restaurant Wallet (Revenue) ───────────────────────────────────────────────

/// Tracks each restaurant owner's accumulated revenue.
/// Money physically sits in admin's bank account; this is a ledger balance.
model RestaurantWallet {
  id             String   @id @default(uuid())
  restaurantId   String   @unique
  balance        Decimal  @default(0) @db.Decimal(18, 2) // Available to withdraw (Online Transfer)
  cashBalance    Decimal  @default(0) @db.Decimal(18, 2) // Directly collected cash
  lifetimeEarned Decimal  @default(0) @db.Decimal(18, 2) // Total ever earned (Cash + Online Transfer)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  restaurant    Restaurant           @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  transactions  WalletTransaction[]
  withdrawals   WithdrawalRequest[]

  @@map("RestaurantWallets")
}

model WalletTransaction {
  id           String   @id @default(uuid())
  walletId     String
  type         String   // "ORDER_REVENUE" | "WITHDRAWAL_DEBIT" | "ADJUSTMENT"
  amount       Decimal  @db.Decimal(18, 2)
  balanceBefore Decimal @db.Decimal(18, 2)
  balanceAfter Decimal  @db.Decimal(18, 2)
  orderId      String?
  paymentId    String?
  description  String?
  metadata     Json?
  createdAt    DateTime @default(now())

  wallet RestaurantWallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("WalletTransactions")
}

/// Withdrawal request from restaurant owner.
/// Admin approves → PayOS disburses → balance deducted.
model WithdrawalRequest {
  id             String    @id @default(uuid())
  walletId       String
  restaurantId   String
  amount         Decimal   @db.Decimal(18, 2)
  status         String    @default("PENDING") // PENDING | PROCESSING | COMPLETED | FAILED | CANCELLED
  bankCode       String    // e.g. "MB", "VCB"
  bankBin        String    // e.g. "970422" for MBBank
  accountNumber  String
  accountName    String
  adminNote      String?
  rejectionReason String?
  externalTxId   String?   // PayOS transaction ID
  processedBy    String?   // Admin userId
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  wallet     RestaurantWallet @relation(fields: [walletId], references: [id])

  @@index([walletId])
  @@index([restaurantId])
  @@index([status])
  @@map("WithdrawalRequests")
}

